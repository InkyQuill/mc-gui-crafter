{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/config.schema.json",
  "productName": "MCGUI Crafter",
  "version": "0.1.0",
  "identifier": "net.inkyquill.mc-gui-crafter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:49320",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MCGUI Crafter",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
